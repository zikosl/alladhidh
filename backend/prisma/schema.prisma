generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StockMovementType {
  IN
  OUT

  @@map("stock_movement_type")
}

enum StockMovementReason {
  purchase
  sale
  loss
  adjustment

  @@map("stock_movement_reason")
}

enum SaleType {
  dine_in
  take_away
  delivery

  @@map("sale_type")
}

enum SaleStatus {
  pending
  preparing
  ready
  paid
  cancelled

  @@map("sale_status")
}

enum PaymentMethod {
  cash
  card

  @@map("payment_method")
}

enum DeliveryStatus {
  pending
  on_the_way
  delivered

  @@map("delivery_status")
}

enum UserStatus {
  active
  disabled

  @@map("user_status")
}

enum ExpenseType {
  fixed
  variable
  exceptional

  @@map("expense_type")
}

enum ExpenseStatus {
  planned
  partial
  paid
  cancelled

  @@map("expense_status")
}

enum FinancePaymentMethod {
  cash
  card
  transfer

  @@map("finance_payment_method")
}

enum ExpenseSourceType {
  manual
  stock_purchase
  payroll_payment
  salary_advance

  @@map("expense_source_type")
}

enum EmploymentType {
  monthly
  daily
  hourly

  @@map("employment_type")
}

enum PayrollPeriodStatus {
  draft
  validated
  paid

  @@map("payroll_period_status")
}

enum PayrollAdjustmentType {
  deduction
  penalty

  @@map("payroll_adjustment_type")
}

enum CashSessionStatus {
  open
  closed

  @@map("cash_session_status")
}

model Product {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(150)
  category  String     @default("General") @db.VarChar(80)
  categoryId Int?      @map("category_id")
  price     Decimal    @db.Decimal(10, 2)
  estimatedCost Decimal @default(0) @map("estimated_cost") @db.Decimal(10, 2)
  sourceType String     @default("recipe") @map("source_type") @db.VarChar(30)
  stockItemId Int?      @map("stock_item_id")
  saleUnitQuantity Decimal @default(1) @map("sale_unit_quantity") @db.Decimal(10, 3)
  isActive  Boolean    @default(true) @map("is_active")
  color     String     @default("#1f2937") @db.VarChar(30)
  icon      String     @default("🍽️") @db.VarChar(10)
  imageUrl  String?    @map("image_url") @db.VarChar(255)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  recipes   Recipe[]
  saleItems SaleItem[]
  categoryRef MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stockItem Ingredient? @relation("DirectSaleProductStockItem", fields: [stockItemId], references: [id], onDelete: SetNull)

  @@index([category], map: "idx_products_category")
  @@index([categoryId], map: "idx_products_category_id")
  @@index([sourceType], map: "idx_products_source_type")
  @@index([stockItemId], map: "idx_products_stock_item_id")
  @@unique([stockItemId, sourceType], map: "uq_products_stock_item_source")
  @@map("products")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique @db.VarChar(80)
  description String?          @db.VarChar(255)
  isSystem    Boolean          @default(true) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  code        String           @unique @db.VarChar(100)
  label       String           @db.VarChar(120)
  module      String           @db.VarChar(80)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at")
  roleLinks   RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int         @map("role_id")
  permissionId Int         @map("permission_id")
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           Int         @id @default(autoincrement())
  fullName     String      @map("full_name") @db.VarChar(150)
  username     String      @unique @db.VarChar(80)
  email        String?     @unique @db.VarChar(150)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  status       UserStatus  @default(active)
  roleId       Int         @map("role_id")
  lastLoginAt  DateTime?   @map("last_login_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  employeeProfile EmployeeProfile?
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Restrict)
  openedCashSessions CashSession[] @relation("CashSessionOpenedBy")
  closedCashSessions CashSession[] @relation("CashSessionClosedBy")

  @@index([roleId], map: "idx_users_role_id")
  @@map("users")
}

model RestaurantTable {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(60)
  zone      String?   @db.VarChar(80)
  capacity  Int       @default(2)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("restaurant_tables")
}

model RestaurantSettings {
  id                  Int      @id
  restaurantName      String   @default("Restaurant Suite") @map("restaurant_name") @db.VarChar(150)
  currency            String   @default("DZD") @db.VarChar(10)
  defaultDeliveryFee  Decimal  @default(0) @map("default_delivery_fee") @db.Decimal(10, 2)
  lowStockThreshold   Decimal  @default(1000) @map("low_stock_threshold") @db.Decimal(10, 2)
  logoUrl             String?  @map("logo_url") @db.VarChar(255)
  receiptTitle        String   @default("Facture client") @map("receipt_title") @db.VarChar(120)
  receiptSubtitle     String?  @map("receipt_subtitle") @db.VarChar(180)
  receiptAddress      String?  @map("receipt_address") @db.VarChar(255)
  receiptPhone        String?  @map("receipt_phone") @db.VarChar(60)
  receiptEmail        String?  @map("receipt_email") @db.VarChar(150)
  receiptWebsite      String?  @map("receipt_website") @db.VarChar(150)
  receiptFacebook     String?  @map("receipt_facebook") @db.VarChar(150)
  receiptInstagram    String?  @map("receipt_instagram") @db.VarChar(150)
  receiptTiktok       String?  @map("receipt_tiktok") @db.VarChar(150)
  receiptWhatsapp     String?  @map("receipt_whatsapp") @db.VarChar(80)
  receiptFooter       String?  @map("receipt_footer") @db.VarChar(255)
  receiptAdditionalNote String? @map("receipt_additional_note") @db.VarChar(255)
  kitchenTicketHeader String?  @map("kitchen_ticket_header") @db.VarChar(180)
  kitchenTicketFooter String?  @map("kitchen_ticket_footer") @db.VarChar(180)
  showContactBlock    Boolean  @default(true) @map("show_contact_block")
  showSocialLinks     Boolean  @default(true) @map("show_social_links")
  showFooterNote      Boolean  @default(true) @map("show_footer_note")
  showLogoInKitchenTicket Boolean @default(false) @map("show_logo_in_kitchen_ticket")
  autoPrintKitchenTicket Boolean @default(true) @map("auto_print_kitchen_ticket")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("restaurant_settings")
}

model MenuCategory {
  id            Int               @id @default(autoincrement())
  name          String            @unique @db.VarChar(80)
  description   String?           @db.VarChar(255)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  products      Product[]

  @@map("menu_categories")
}

model Ingredient {
  id              Int             @id @default(autoincrement())
  name            String          @unique @db.VarChar(150)
  category        String          @default("General") @db.VarChar(80)
  measurementType String          @default("weight") @map("measurement_type") @db.VarChar(20)
  unit            String          @default("g") @db.VarChar(20)
  usageType       String          @default("recipe_only") @map("usage_type") @db.VarChar(30)
  purchasePrice   Decimal         @map("purchase_price") @db.Decimal(10, 4)
  minimumStock    Decimal?        @map("minimum_stock") @db.Decimal(10, 3)
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  purchases       Purchase[]
  recipes         Recipe[]
  stockMovements  StockMovement[]
  directSaleProducts Product[]     @relation("DirectSaleProductStockItem")
  categoryRef     IngredientCategory @relation(fields: [category], references: [name], onDelete: Restrict, onUpdate: Cascade)

  @@index([category], map: "idx_ingredients_category")
  @@index([isActive], map: "idx_ingredients_active")
  @@map("ingredients")
}

model IngredientCategory {
  id          Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(80)
  description String?      @db.VarChar(255)
  usageType   String       @default("recipe_only") @map("usage_type") @db.VarChar(30)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  ingredients Ingredient[]

  @@map("ingredient_categories")
}

model Recipe {
  id           Int        @id @default(autoincrement())
  productId    Int        @map("product_id")
  ingredientId Int        @map("ingredient_id")
  quantity     Decimal    @db.Decimal(10, 3)
  unit         String     @default("g") @db.VarChar(20)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId], map: "uq_recipe_product_ingredient")
  @@map("recipes")
}

model StockMovement {
  id           Int                 @id @default(autoincrement())
  ingredientId Int                 @map("ingredient_id")
  type         StockMovementType
  quantity     Decimal             @db.Decimal(10, 3)
  reason       StockMovementReason
  date         DateTime            @default(now())
  createdAt    DateTime            @default(now()) @map("created_at")
  ingredient   Ingredient          @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([ingredientId, date], map: "idx_stock_movements_ingredient_date")
  @@map("stock_movements")
}

model Sale {
  id             Int             @id @default(autoincrement())
  type           SaleType
  status         SaleStatus      @default(pending)
  tableNumber    String?         @map("table_number") @db.VarChar(30)
  customerName   String?         @map("customer_name") @db.VarChar(150)
  phone          String?         @db.VarChar(50)
  address        String?         @db.VarChar(255)
  notes          String?
  deliveryFee    Decimal         @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  deliveryStatus DeliveryStatus? @map("delivery_status")
  totalPrice     Decimal         @default(0) @map("total_price") @db.Decimal(10, 2)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  payments       Payment[]
  saleItems      SaleItem[]

  @@index([createdAt], map: "idx_sales_created_at")
  @@index([status], map: "idx_sales_status")
  @@index([deliveryStatus], map: "idx_sales_delivery_status")
  @@map("sales")
}

model SaleItem {
  id        Int      @id @default(autoincrement())
  saleId    Int      @map("sale_id")
  productId Int      @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId], map: "idx_sale_items_sale_id")
  @@map("sale_items")
}

model Purchase {
  id           Int        @id @default(autoincrement())
  ingredientId Int        @map("ingredient_id")
  quantity     Decimal    @db.Decimal(10, 3)
  totalPrice   Decimal    @map("total_price") @db.Decimal(10, 2)
  date         DateTime   @default(now())
  createdAt    DateTime   @default(now()) @map("created_at")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([date], map: "idx_purchases_date")
  @@map("purchases")
}

model Expense {
  id            Int                   @id @default(autoincrement())
  amount        Decimal               @db.Decimal(10, 2)
  category      String                @db.VarChar(100)
  categoryId    Int?                  @map("category_id")
  type          ExpenseType           @default(variable)
  status        ExpenseStatus         @default(paid)
  paymentMethod FinancePaymentMethod? @map("payment_method")
  supplierName  String?               @map("supplier_name") @db.VarChar(120)
  description   String?               @db.VarChar(255)
  sourceType    ExpenseSourceType     @default(manual) @map("source_type")
  sourceId      Int?                  @map("source_id")
  sourceLabel   String?               @map("source_label") @db.VarChar(160)
  dueDate       DateTime?             @map("due_date")
  paidAt        DateTime?             @map("paid_at")
  date          DateTime              @default(now())
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  categoryRef   ExpenseCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([date], map: "idx_expenses_date")
  @@index([categoryId], map: "idx_expenses_category_id")
  @@index([sourceType, sourceId], map: "idx_expenses_source")
  @@unique([sourceType, sourceId], map: "uq_expenses_source")
  @@map("expenses")
}

model ExpenseCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?   @db.VarChar(255)
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  expenses    Expense[]

  @@map("expense_categories")
}

model Payment {
  id        Int           @id @default(autoincrement())
  saleId    Int           @map("sale_id")
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now()) @map("created_at")
  sale      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model EmployeeProfile {
  id             Int             @id @default(autoincrement())
  userId         Int             @unique @map("user_id")
  position       String?         @db.VarChar(120)
  employmentType EmploymentType  @default(monthly) @map("employment_type")
  baseSalary     Decimal         @default(0) @map("base_salary") @db.Decimal(10, 2)
  hireDate       DateTime?       @map("hire_date")
  isActive       Boolean         @default(true) @map("is_active")
  payrollNotes   String?         @map("payroll_notes") @db.VarChar(255)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  advances       SalaryAdvance[]
  payrollEntries PayrollEntry[]
  payrollAdjustments PayrollAdjustment[]

  @@index([isActive], map: "idx_employee_profiles_active")
  @@map("employee_profiles")
}

model SalaryAdvance {
  id              Int             @id @default(autoincrement())
  employeeId      Int             @map("employee_id")
  amount          Decimal         @db.Decimal(10, 2)
  remainingAmount Decimal         @map("remaining_amount") @db.Decimal(10, 2)
  reason          String          @db.VarChar(160)
  note            String?         @db.VarChar(255)
  date            DateTime        @default(now())
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  employee        EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  settlements     SalaryAdvanceSettlement[]

  @@index([employeeId, date], map: "idx_salary_advances_employee_date")
  @@map("salary_advances")
}

model PayrollPeriod {
  id        Int                 @id @default(autoincrement())
  label     String              @db.VarChar(120)
  startDate DateTime            @map("start_date")
  endDate   DateTime            @map("end_date")
  status    PayrollPeriodStatus @default(draft)
  notes     String?             @db.VarChar(255)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  entries   PayrollEntry[]
  adjustments PayrollAdjustment[]

  @@index([startDate, endDate], map: "idx_payroll_periods_range")
  @@map("payroll_periods")
}

model PayrollEntry {
  id               Int             @id @default(autoincrement())
  periodId         Int             @map("period_id")
  employeeId       Int             @map("employee_id")
  baseSalary       Decimal         @map("base_salary") @db.Decimal(10, 2)
  bonuses          Decimal         @default(0) @db.Decimal(10, 2)
  deductions       Decimal         @default(0) @db.Decimal(10, 2)
  advanceDeduction Decimal         @default(0) @map("advance_deduction") @db.Decimal(10, 2)
  netSalary        Decimal         @map("net_salary") @db.Decimal(10, 2)
  notes            String?         @db.VarChar(255)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  employee         EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period           PayrollPeriod   @relation(fields: [periodId], references: [id], onDelete: Cascade)
  payments         PayrollPayment[]
  advanceSettlements SalaryAdvanceSettlement[]

  @@unique([periodId, employeeId], map: "uq_payroll_entry_period_employee")
  @@index([employeeId], map: "idx_payroll_entries_employee")
  @@map("payroll_entries")
}

model PayrollAdjustment {
  id         Int                   @id @default(autoincrement())
  employeeId Int                  @map("employee_id")
  periodId  Int?                  @map("period_id")
  type       PayrollAdjustmentType @default(deduction)
  amount     Decimal              @db.Decimal(10, 2)
  reason     String               @db.VarChar(160)
  note       String?              @db.VarChar(255)
  date       DateTime             @default(now())
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")
  employee   EmployeeProfile      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period     PayrollPeriod?       @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@index([employeeId, date], map: "idx_payroll_adjustments_employee_date")
  @@index([periodId], map: "idx_payroll_adjustments_period")
  @@map("payroll_adjustments")
}

model CashSession {
  id            Int               @id @default(autoincrement())
  businessDate  DateTime          @unique @map("business_date") @db.Date
  openingAmount Decimal           @default(0) @map("opening_amount") @db.Decimal(10, 2)
  closingAmount Decimal?          @map("closing_amount") @db.Decimal(10, 2)
  expectedCash  Decimal           @default(0) @map("expected_cash") @db.Decimal(10, 2)
  difference    Decimal           @default(0) @db.Decimal(10, 2)
  status        CashSessionStatus @default(open)
  openedById    Int?              @map("opened_by_id")
  closedById    Int?              @map("closed_by_id")
  notes         String?           @db.VarChar(255)
  openedAt      DateTime          @default(now()) @map("opened_at")
  closedAt      DateTime?         @map("closed_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  openedBy      User?             @relation("CashSessionOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  closedBy      User?             @relation("CashSessionClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@index([businessDate], map: "idx_cash_sessions_business_date")
  @@index([status], map: "idx_cash_sessions_status")
  @@map("cash_sessions")
}

model PayrollPayment {
  id        Int                  @id @default(autoincrement())
  entryId    Int                 @map("entry_id")
  amount     Decimal             @db.Decimal(10, 2)
  method     FinancePaymentMethod
  paidAt     DateTime            @map("paid_at")
  note       String?             @db.VarChar(255)
  createdAt  DateTime            @default(now()) @map("created_at")
  entry      PayrollEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, paidAt], map: "idx_payroll_payments_entry_paid_at")
  @@map("payroll_payments")
}

model SalaryAdvanceSettlement {
  advanceId Int          @map("advance_id")
  entryId   Int          @map("entry_id")
  amount    Decimal      @db.Decimal(10, 2)
  createdAt DateTime     @default(now()) @map("created_at")
  advance   SalaryAdvance @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  entry     PayrollEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@id([advanceId, entryId])
  @@index([entryId], map: "idx_salary_advance_settlements_entry")
  @@map("salary_advance_settlements")
}
